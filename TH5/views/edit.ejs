<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Sửa bài viết</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <h1>Sửa bài viết</h1>
    
    <!-- Gửi dữ liệu cập nhật tới route update kèm theo ID -->
    <form action="/blogposts/update/<%= post._id %>" method="POST" class="post-card">
        <p>
            Tiêu đề:<br>
            <input type="text" name="title" value="<%= post.title %>" required>
        </p>
        <p>
            Nội dung:<br>
            <textarea name="body" rows="5" required><%= post.body %></textarea>
        </p>
        <button type="submit" class="btn btn-primary">Cập nhật bài viết</button>
    </form>
    
    <br>
    <a href="/" class="btn btn-warning">🔙 Hủy & Về trang chủ</a>
</body>
</html>